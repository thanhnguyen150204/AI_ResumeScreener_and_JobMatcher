

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"

}

enum Role {
  USER 
  RECRUITER
  ADMIN
}

model User{
  id Int @id @default(autoincrement())
  email String @unique
  passwordHash String 
  role Role @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  token RefreshToken[]
}

model RefreshToken{
  id Int @id @default(autoincrement())
  token String @unique
  userId Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

